#: getblitz-payment-gateway.php:69
msgid "Settings"
msgstr "Einstellungen"

#: includes/class-wc-gateway-getblitz.php:34
msgid "GetBlitz SEPA Instant"
msgstr "GetBlitz SEPA Instant"

#: includes/class-wc-gateway-getblitz.php:35
msgid "Accept SEPA Instant Transfers securely via GetBlitz."
msgstr "Akzeptieren Sie SEPA-Sofortüberweisungen sicher über GetBlitz."

#: includes/class-wc-gateway-getblitz.php:58
msgid "Enable/Disable"
msgstr "Aktivieren/Deaktivieren"

#: includes/class-wc-gateway-getblitz.php:60
msgid "Enable GetBlitz Payment"
msgstr "GetBlitz-Zahlung aktivieren"

#: includes/class-wc-gateway-getblitz.php:64
msgid "Title"
msgstr "Titel"

#: includes/class-wc-gateway-getblitz.php:66
msgid "This controls the title which the user sees during checkout."
msgstr "Dieser Text wird dem Kunden während des Bestellvorgangs als Zahlungsmethoden-Titel angezeigt."

#: includes/class-wc-gateway-getblitz.php:67
msgid "GetBlitz SEPA Instant Transfer"
msgstr "GetBlitz SEPA-Sofortüberweisung"

#: includes/class-wc-gateway-getblitz.php:71
msgid "Description"
msgstr "Beschreibung"

#: includes/class-wc-gateway-getblitz.php:73
msgid "This controls the description which the user sees during checkout."
msgstr "Diese Beschreibung wird dem Kunden während des Bestellvorgangs angezeigt."

#: includes/class-wc-gateway-getblitz.php:74
msgid "Pay instantly from your bank account via SEPA Instant."
msgstr "Zahlen Sie sofort von Ihrem Bankkonto per SEPA-Sofortüberweisung."

#: includes/class-wc-gateway-getblitz.php:77
msgid "API Key"
msgstr "API-Schlüssel"

#: includes/class-wc-gateway-getblitz.php:79
msgid "Your GetBlitz Organization API Key."
msgstr "Ihr GetBlitz-Organisations-API-Schlüssel."

#: includes/class-wc-gateway-getblitz.php:84
msgid "Webhook Secret"
msgstr "Webhook-Geheimnis"

#: includes/class-wc-gateway-getblitz.php:86
msgid "The secret used to verify webhook signatures. Retrieve from GetBlitz Dashboard."
msgstr "Das Geheimnis zur Überprüfung von Webhook-Signaturen. Abrufbar im GetBlitz-Dashboard."

#: includes/class-wc-gateway-getblitz.php:91
msgid "Base API URL"
msgstr "Basis-API-URL"

#: includes/class-wc-gateway-getblitz.php:93
msgid "Base API URL for self-hosted instances. Defaults to https://app.getblitz.io"
msgstr "Basis-API-URL für selbst gehostete Instanzen. Standard: https://app.getblitz.io"

#: includes/class-wc-gateway-getblitz.php:98
msgid "WebSocket URL"
msgstr "WebSocket-URL"

#: includes/class-wc-gateway-getblitz.php:100
msgid "Optional WebSocket URL for real-time updates on self-hosted instances."
msgstr "Optionale WebSocket-URL für Echtzeit-Updates bei selbst gehosteten Instanzen."

#: includes/class-wc-gateway-getblitz.php:111
msgid "GetBlitz arrangement error: Ensure API Key is configured."
msgstr "GetBlitz-Konfigurationsfehler: Bitte stellen Sie sicher, dass der API-Schlüssel konfiguriert ist."

#: includes/class-wc-gateway-getblitz.php:119
msgid "GetBlitz currently only supports EUR currency."
msgstr "GetBlitz unterstützt derzeit nur die Währung EUR."

#: includes/class-wc-gateway-getblitz.php:146
msgid "An error occurred communicating with the payment gateway."
msgstr "Bei der Kommunikation mit dem Zahlungsgateway ist ein Fehler aufgetreten."

#: includes/class-wc-gateway-getblitz.php:156
msgid "Could not create payment session. Please try again."
msgstr "Die Zahlungssitzung konnte nicht erstellt werden. Bitte versuchen Sie es erneut."

#: includes/class-wc-gateway-getblitz.php:166
msgid "Awaiting GetBlitz SEPA payment."
msgstr "Warte auf GetBlitz SEPA-Zahlung."

#: includes/class-wc-gateway-getblitz.php:181
msgid "Missing payment session details. Please try placing your order again."
msgstr "Zahlungssitzungsdetails fehlen. Bitte geben Sie Ihre Bestellung erneut auf."

#: includes/class-wc-gateway-getblitz.php:216
msgid "Confirming your payment, please wait\xe2\x80\xa6"
msgstr "Ihre Zahlung wird bestätigt, bitte warten\xe2\x80\xa6"

#: includes/class-wc-gateway-getblitz.php:238
msgid "Unable to load payment widget. Please refresh and try again."
msgstr "Das Zahlungs-Widget konnte nicht geladen werden. Bitte aktualisieren Sie die Seite und versuchen Sie es erneut."

#: includes/class-wc-gateway-getblitz.php:272
#: includes/class-wc-gateway-getblitz.php:279
msgid "Payment received \xe2\x80\x94 your order is being processed. You will receive a confirmation email shortly."
msgstr "Zahlung eingegangen \xe2\x80\x94 Ihre Bestellung wird bearbeitet. Sie erhalten in Kürze eine Bestätigungs-E-Mail."

#: includes/class-wc-gateway-getblitz.php:368
msgid "GetBlitz payment successfully confirmed via webhook."
msgstr "GetBlitz-Zahlung erfolgreich per Webhook bestätigt."

#: includes/class-wc-gateway-getblitz.php:374
#, php-format
msgid "GetBlitz: Partial payment received online: %s EUR."
msgstr "GetBlitz: Teilzahlung eingegangen: %s EUR."

#: includes/class-wc-gateway-getblitz.php:378
msgid "GetBlitz payment failed from provider."
msgstr "GetBlitz-Zahlung vom Anbieter abgelehnt."

#: includes/class-wc-gateway-getblitz.php:383
msgid "GetBlitz payment session expired."
msgstr "GetBlitz-Zahlungssitzung abgelaufen."

#: includes/class-wc-gateway-getblitz.php:432
msgid "GetBlitz payment verified via API during checkout."
msgstr "GetBlitz-Zahlung während des Bestellvorgangs per API verifiziert."

#: includes/class-wc-gateway-getblitz.php:444
msgid "GetBlitz payment received by client; awaiting final server confirmation."
msgstr "GetBlitz-Zahlung vom Client empfangen; warte auf abschließende Serverbestätigung."

msgid "Step-by-Step Configuration"
msgstr "Schritt-für-Schritt-Konfiguration"

msgid "Whitelist your Allowed Origin"
msgstr "Autorisierte Herkunft (Allowed Origin) angeben"

msgid "The allowed origin determines where your GetBlitz payment widget can be loaded."
msgstr "Die autorisierte Herkunft bestimmt, wo Ihr GetBlitz-Zahlungs-Widget geladen werden darf."

msgid "Go to:"
msgstr "Gehe zu:"

msgid "Value to add:"
msgstr "Einzufügender Wert:"

msgid "Allowed Origin copied to clipboard!"
msgstr "Allowed Origin in die Zwischenablage kopiert!"

msgid "Copy Link"
msgstr "Link kopieren"

msgid "Configure the Webhook URL"
msgstr "Webhook-URL konfigurieren"

msgid "We use webhooks to get real-time status updates on payments."
msgstr "Wir verwenden Webhooks, um Echtzeit-Statusaktualisierungen zu Zahlungen zu erhalten."

msgid "URL to add:"
msgstr "Einzufügende URL:"

msgid "Webhook URL copied to clipboard!"
msgstr "Webhook-URL in die Zwischenablage kopiert!"

msgid "Important: Make sure to copy the Webhook Secret from the GetBlitz dashboard and paste it in the \"Webhook Secret\" field below."
msgstr "Wichtig: Kopieren Sie das Webhook-Secret aus dem GetBlitz-Dashboard und fügen Sie es unten in das Feld \"Webhook Secret\" ein."

msgid "Generate an API Key"
msgstr "API-Schlüssel generieren"

msgid "The API key allows this plugin to communicate with GetBlitz."
msgstr "Der API-Schlüssel ermöglicht es diesem Plugin, mit GetBlitz zu kommunizieren."

msgid "Paste the generated API Key in the \"API Key\" field below."
msgstr "Fügen Sie den generierten API-Schlüssel unten in das Feld \"API-Schlüssel\" ein."

msgid "Your GetBlitz Organization API Key. Generate it at Getblitz -> Settings -> API Keys -> Generate New Key."
msgstr "Ihr GetBlitz-Organisations-API-Schlüssel. Generieren Sie ihn unter Getblitz -> Settings -> API Keys -> Generate New Key."

msgid "The secret used to verify webhook signatures. Retrieve from Getblitz -> Settings -> Webhooks -> Add Webhook."
msgstr "Das Secret zur Verifizierung von Webhook-Signaturen. Abrufbar unter Getblitz -> Settings -> Webhooks -> Add Webhook."
